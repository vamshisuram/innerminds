---
import SectionHeader from "../SectionHeader.astro";
import CardStep from "../CardStep.astro";
---

<section id="how-it-works" class="w-full bg-bg-cards">
<div class="flex flex-col items-center gap-12 py-16 lg:py-24 px-6 md:px-12 lg:px-[120px] max-w-[1440px] mx-auto">
  <SectionHeader
    title="How It Works"
    subtitle="Getting started is simple — just 3 easy steps from Awareness to Action."
  />
  <div class="flex flex-col md:flex-row gap-6 md:gap-8 w-full">
    <CardStep
      number="1"
      icon="clipboard-text"
      title="Fill in an Intake Form"
      description="Answer a few questions so we get to know you."
    />
    <CardStep
      number="2"
      icon="users"
      title="A counsellor will be Appointed"
      description="The counsellor will be appointed to support you in your journey."
    />
    <CardStep
      number="3"
      icon="calendar-check"
      title="Begin Session on your Schedule."
      description="Meet your counselor via scheduled online video sessions."
    />
  </div>
</div>
</section>
