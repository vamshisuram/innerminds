---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div class="flex flex-col items-center gap-2 bg-bg-cards rounded-lg shadow-[0_2px_8px_#1A2B3C14] p-4 md:p-6">
  <span class="font-heading text-3xl md:text-[40px] font-bold text-primary">{number}</span>
  <p class="font-body text-xs md:text-sm text-text-secondary leading-[1.5] text-center">{label}</p>
</div>
