---

<div class="flex flex-col items-center gap-4 bg-bg-cards rounded-lg shadow-[0_2px_8px_#1A2B3C14] p-6 md:p-8 flex-1">
  <div class="flex items-center justify-center w-12 h-12 bg-primary text-white rounded-full">
    <span class="font-body text-xl font-bold">{number}</span>
  </div>
  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="text-primary" viewBox="0 0 256 256" aria-hidden="true">
    <Fragment set:html={iconPaths[icon] || iconPaths["clipboard-text"]} />
  </svg>
  <h3 class="font-heading text-xl font-semibold text-text-primary text-center">{title}</h3>
  <p class="font-body text-base text-text-secondary leading-[1.6] text-center">{description}</p>
</div>
