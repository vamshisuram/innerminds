---
import Button from "../Button.astro";
---

<section id="get-started" class="w-full bg-primary">
<div class="flex flex-col items-center gap-6 py-16 lg:py-24 px-6 md:px-12 lg:px-[120px] max-w-[1440px] mx-auto">
  <h2 class="font-heading text-3xl md:text-[40px] font-bold text-white text-center max-w-[680px]">
    Clarity begins with a conversation.
  </h2>
  <p class="font-body text-lg md:text-xl font-normal text-white/80 text-center max-w-[600px] leading-[1.6]">
    You don't have to figure it out alone. Professional support is available right now.
  </p>
  <div class="flex flex-col sm:flex-row items-center gap-4">
    <Button variant="primary" href="tel:+918828107441">
      Book the Appointment
    </Button>
    <Button variant="secondary-light" href="#services">Explore Services First</Button>
  </div>
  <!-- <p class="font-body text-sm text-white/70 text-center">
    Your information is encrypted and never shared with your employer.
  </p> -->
</div>
</section>
