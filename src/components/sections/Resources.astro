---
import SectionHeader from "../SectionHeader.astro";
import CardResource from "../CardResource.astro";
---

<section id="resources" class="w-full bg-bg-feature">
<div class="flex flex-col items-center gap-12 py-16 lg:py-24 px-6 md:px-12 lg:px-[120px] max-w-[1440px] mx-auto">
  <SectionHeader
    title="Resources & Self-Help"
    subtitle="Explore tools and articles to support your wellbeing — even before booking a session."
  />
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
    <CardResource
      image="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=800&h=400&fit=crop"
      tag="Article"
      tagColor="green"
      title="5 Techniques to Manage Workplace Stress"
      description="Simple, evidence-based strategies you can use today."
    />
    <CardResource
      image="https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=800&h=400&fit=crop"
      tag="Guided Exercise"
      tagColor="teal"
      title="Mindful Breathing for Anxiety Relief"
      description="A 5-minute guided exercise to calm your mind."
    />
    <CardResource
      image="https://images.unsplash.com/photo-1517842645767-c639042777db?w=800&h=400&fit=crop"
      tag="Self-Assessment"
      tagColor="amber"
      title="How Are You Really Feeling? A Quick Check-In"
      description="Take 2 minutes to check in with yourself."
    />
  </div>
</div>
</section>
