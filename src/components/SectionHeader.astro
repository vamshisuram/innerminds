---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex flex-col items-center gap-3 max-w-[680px] text-center">
  <h2 class="font-heading text-[32px] font-bold text-text-primary">{title}</h2>
  <p class="font-body text-lg text-text-secondary leading-[1.6]">{subtitle}</p>
</div>
