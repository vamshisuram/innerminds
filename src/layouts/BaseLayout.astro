---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Inner Mind Solutions — Confidential Counseling",
  description = "Licensed counselors available 24/7 — completely free and confidential through your employer.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:text-sm focus:font-semibold">Skip to main content</a>
    <slot />

    <!-- Cookie consent banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[100] bg-text-primary border-t border-white/10 hidden">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 px-6 py-4 max-w-[1440px] mx-auto">
        <p class="font-body text-sm text-white/80 text-center sm:text-left">
          Inner Mind Solutions uses cookies to deliver and enhance the quality of its services and to analyze traffic.
          <a href="/privacy" class="text-primary-light hover:text-white transition-colors underline">Learn more.</a>
        </p>
        <button
          id="cookie-accept"
          class="shrink-0 font-body text-sm font-semibold text-white bg-primary hover:bg-primary-dark px-5 py-2 rounded cursor-pointer transition-colors"
        >
          Okay
        </button>
      </div>
    </div>

    <script>
      const banner = document.getElementById('cookie-banner');
      const btn = document.getElementById('cookie-accept');

      if (!localStorage.getItem('cookie-consent')) {
        banner?.classList.remove('hidden');
      }

      btn?.addEventListener('click', () => {
        localStorage.setItem('cookie-consent', 'accepted');
        banner?.classList.add('hidden');
      });
    </script>
  </body>
</html>
