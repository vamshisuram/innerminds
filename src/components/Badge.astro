---
interface Props {
  variant?: "confidential" | "certification";
  label: string;
  icon?: string;
}

const { variant = "confidential", label } = Astro.props;
---

{variant === "confidential" ? (
  <div class="inline-flex items-center gap-2 bg-primary-light text-primary rounded-full px-4 py-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
      <path d="M208,40H48A16,16,0,0,0,32,56v58.77c0,89.61,75.82,119.34,91,124.39a15.53,15.53,0,0,0,10,0c15.2-5.05,91-34.78,91-124.39V56A16,16,0,0,0,208,40Zm-34.34,69.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path>
    </svg>
    <span class="font-body text-sm font-semibold">{label}</span>
  </div>
) : (
  <div class="inline-flex items-center gap-2 bg-bg-cards border border-border-default rounded-full px-4 py-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="text-secondary" viewBox="0 0 256 256">
      <path d="M173.66,98.34a8,8,0,0,1,0,11.32l-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35A8,8,0,0,1,173.66,98.34ZM232,128A104,104,0,1,1,128,24,104.11,104.11,0,0,1,232,128Zm-16,0a88,88,0,1,0-88,88A88.1,88.1,0,0,0,216,128Z"></path>
    </svg>
    <span class="font-body text-sm font-medium text-text-secondary">{label}</span>
  </div>
)}
