---
import Button from "../Button.astro";
---

<section id="get-started" class="w-full bg-primary">
<div class="flex flex-col items-center gap-6 py-24 px-[120px] max-w-[1440px] mx-auto">
  <h2 class="font-heading text-[40px] font-bold text-white text-center max-w-[680px]">
    Take the First Step Toward Feeling Better
  </h2>
  <p class="font-body text-xl font-normal text-white/80 text-center max-w-[600px] leading-[1.6]">
    You don't have to figure it out alone. Confidential, professional support is available right now — at no cost to you.
  </p>
  <div class="flex items-center gap-4">
    <Button variant="primary" href="#">Find Your Counselor</Button>
    <Button variant="secondary-light" href="#">Explore Services First</Button>
  </div>
  <p class="font-body text-sm text-white/60">
    Your information is encrypted and never shared with your employer.
  </p>
</div>
</section>
