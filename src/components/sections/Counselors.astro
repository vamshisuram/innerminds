---
import SectionHeader from "../SectionHeader.astro";
import CardCounselor from "../CardCounselor.astro";
---

<section id="counselors" class="w-full bg-bg-feature">
<div class="flex flex-col items-center gap-12 py-16 lg:py-24 px-6 md:px-12 lg:px-[120px] max-w-[1440px] mx-auto">
  <SectionHeader
    title="Meet Your Counselors"
    subtitle="Our diverse team of licensed professionals specializes in the challenges you face every day."
  />
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full">
    <CardCounselor
      name="Malini. Parthasarathy Soni"
      credentials="Counselor (Founder)"
      photo="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=560&h=400&fit=crop"
      tags={[
        { label: "Anxiety", color: "primary" },
        { label: "Burnout", color: "primary" },
        { label: "Stress", color: "secondary" },
      ]}
    />
    <CardCounselor
      name="Sivambiga. A"
      credentials="Counselor (Founder)"
      photo="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=560&h=400&fit=crop"
