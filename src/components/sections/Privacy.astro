---
import Badge from "../Badge.astro";
import PrivacyItem from "../PrivacyItem.astro";
---

<section class="flex items-start gap-16 w-full bg-bg-feature py-24 px-[120px] max-w-[1440px] mx-auto">
  <!-- Left: Icon + Badges -->
  <div class="flex flex-col items-center gap-6 w-[340px] shrink-0">
    <div class="flex items-center justify-center w-[120px] h-[120px] bg-primary rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" class="text-white" viewBox="0 0 256 256">
        <path d="M208,40H48A16,16,0,0,0,32,56v58.77c0,89.61,75.82,119.34,91,124.39a15.53,15.53,0,0,0,10,0c15.2-5.05,91-34.78,91-124.39V56A16,16,0,0,0,208,40Zm-34.34,69.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path>
      </svg>
    </div>
    <div class="flex gap-3">
      <Badge variant="certification" label="HIPAA Compliant" />
      <Badge variant="certification" label="SOC 2 Type II" />
    </div>
  </div>

  <!-- Right: Content -->
  <div class="flex flex-col gap-6 flex-1">
    <h2 class="font-heading text-[32px] font-bold text-text-primary">Your Privacy Is Our Promise</h2>
    <p class="font-body text-lg text-text-secondary leading-[1.6]">
      We understand that confidentiality is your biggest concern. Here's exactly how we protect you.
    </p>
    <div class="flex flex-col gap-5">
      <PrivacyItem
        icon="eye-slash"
        question="Can my employer see that I used this service?"
        answer="No. Only anonymized aggregate data is shared. Your individual usage is never disclosed."
      />
      <PrivacyItem
        icon="lock-simple"
        question="Is what I discuss private?"
        answer="Yes. Your conversations are protected by therapist-client privilege. Everything stays between you and your counselor."
      />
      <PrivacyItem
        icon="shield-checkered"
        question="Is my data secure?"
        answer="End-to-end encrypted infrastructure protects your data. We meet the highest standards of healthcare data security."
      />
      <PrivacyItem
        icon="briefcase"
        question="Will this affect my job?"
        answer="No. Your participation cannot be used in performance reviews, promotions, or any employment decisions."
      />
    </div>
  </div>
</section>
