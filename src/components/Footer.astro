---
---

<footer class="w-full bg-text-primary">
  <!-- Main Footer -->
  <div class="flex gap-12 justify-between py-16 px-[120px] max-w-[1440px] mx-auto">
    <!-- Brand Column -->
    <div class="flex flex-col gap-4 w-[280px]">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="text-accent" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M223.45,40.07a8,8,0,0,0-7.52-7.52C139.8,28.08,78.82,50,52.82,94a87.09,87.09,0,0,0-12.76,49c.57,15.92,5.21,32,13.79,47.85l-19.51,19.5a8,8,0,0,0,11.32,11.32l19.51-19.51C81.18,210.93,97.34,215.56,113.25,216.14q2.56.09,5.09.09A86.76,86.76,0,0,0,162,203.18C206,177.18,227.93,116.21,223.45,40.07ZM153.75,189.5c-22.75,13.78-49.68,14-76.71.77L165.9,101.4a8,8,0,0,0-11.31-11.31L65.73,179c-13.19-27-13-54,.77-76.71,22.09-36.47,74.3-56.44,141.31-54.06C209.19,115.2,189.22,167.41,153.75,189.5Z"></path>
        </svg>
        <span class="font-body text-lg font-bold text-white">Inner Mind Solutions</span>
      </div>
      <p class="font-body text-sm text-white/70 leading-[1.7]">
        Confidential, employer-sponsored counseling and wellness services for employees and their families.
      </p>
    </div>

    <!-- Services Column -->
    <div class="flex flex-col gap-3 w-[180px]">
      <h3 class="font-body text-sm font-semibold text-white tracking-wide">Services</h3>
      <a href="#services" class="font-body text-sm text-white/70 hover:text-white transition-colors">Individual Counseling</a>
      <a href="#services" class="font-body text-sm text-white/70 hover:text-white transition-colors">Couples Counseling</a>
      <a href="#services" class="font-body text-sm text-white/70 hover:text-white transition-colors">Family Counseling</a>
      <a href="#services" class="font-body text-sm text-white/70 hover:text-white transition-colors">Group Sessions</a>
      <a href="#services" class="font-body text-sm text-white/70 hover:text-white transition-colors">For Employers</a>
    </div>

    <!-- Resources Column -->
    <div class="flex flex-col gap-3 w-[180px]">
      <h3 class="font-body text-sm font-semibold text-white tracking-wide">Resources</h3>
      <a href="#resources" class="font-body text-sm text-white/70 hover:text-white transition-colors">Blog & Articles</a>
      <a href="#resources" class="font-body text-sm text-white/70 hover:text-white transition-colors">Self-Help Tools</a>
      <a href="#faq" class="font-body text-sm text-white/70 hover:text-white transition-colors">FAQs</a>
      <a href="#resources" class="font-body text-sm text-white/70 hover:text-white transition-colors">Wellness Library</a>
    </div>

    <!-- Contact Column -->
    <div class="flex flex-col gap-3 w-[200px]">
      <h3 class="font-body text-sm font-semibold text-white tracking-wide">Contact</h3>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-white/60" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46Z"></path>
        </svg>
        <span class="font-body text-sm text-white/70">1-800-555-0199</span>
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-white/60" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48ZM203.43,64,128,133.15,52.57,64ZM216,192H40V74.19l82.59,75.71a8,8,0,0,0,10.82,0L216,74.19V192Z"></path>
        </svg>
        <span class="font-body text-sm text-white/70">support@innermindsolutions.com</span>
      </div>
      <span class="font-body text-sm font-medium text-accent">Available 24/7</span>
    </div>
  </div>

  <!-- Crisis Strip -->
  <div class="w-full bg-[#2A3D4E]">
    <div class="flex items-center justify-center gap-2 py-4 px-[120px] max-w-[1440px] mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="text-white shrink-0" viewBox="0 0 256 256" aria-hidden="true">
        <path d="M152.27,37.93a8,8,0,0,1,9.8-5.66,86.22,86.22,0,0,1,61.66,61.66,8,8,0,0,1-5.66,9.8A8.23,8.23,0,0,1,216,104a8,8,0,0,1-7.73-5.93,70.35,70.35,0,0,0-50.33-50.34A8,8,0,0,1,152.27,37.93Zm-2.33,41.8c13.79,3.68,22.65,12.55,26.33,26.34A8,8,0,0,0,184,112a8.23,8.23,0,0,0,2.07-.27,8,8,0,0,0,5.66-9.8c-5.12-19.16-18.5-32.54-37.66-37.66a8,8,0,1,0-4.13,15.46Zm72.43,95.87-47.11-21.11a8,8,0,0,0-6.41.29,8.15,8.15,0,0,0-4.07,4.5l-14,33.16c-17.74-7.15-35.79-19.58-51.4-35.19s-28-33.66-35.19-51.4l33.16-14a8.15,8.15,0,0,0,4.5-4.07,8,8,0,0,0,.29-6.41L81.73,34.63a8,8,0,0,0-9.57-4.89L32,40.73A8,8,0,0,0,26.17,49,224.07,224.07,0,0,0,207,229.83a8,8,0,0,0,8.26-5.82l10.99-40.17A8,8,0,0,0,222.37,175.6Z"></path>
      </svg>
      <p class="font-body text-[13px] text-white text-center">
        If you or someone you know is in crisis: Call or text 988 &nbsp;|&nbsp; Crisis Text Line: Text HOME to 741741 &nbsp;|&nbsp; Call 911 for emergencies
      </p>
    </div>
  </div>

  <!-- Legal Bar -->
  <div class="flex items-center justify-between py-5 px-[120px] border-t border-white/10 max-w-[1440px] mx-auto w-full">
    <span class="font-body text-xs text-white/70">&copy; 2026 Inner Mind Solutions. All rights reserved.</span>
    <div class="flex gap-6">
      <a href="/privacy" class="font-body text-xs text-white/70 hover:text-white transition-colors">Privacy Policy</a>
      <a href="/terms" class="font-body text-xs text-white/70 hover:text-white transition-colors">Terms of Service</a>
      <a href="/accessibility" class="font-body text-xs text-white/70 hover:text-white transition-colors">Accessibility</a>
    </div>
  </div>
</footer>
