---
interface Props {
  name: string;
  credentials: string;
  photo: string;
  tags: { label: string; color?: "primary" | "secondary" }[];
}

const { name, credentials, photo, tags } = Astro.props;

const tagColors = {
  primary: "bg-primary-light text-primary",
  secondary: "bg-secondary-light text-secondary",
};
---

<div class="flex flex-col bg-bg-cards rounded-lg shadow-[0_2px_8px_#1A2B3C14] overflow-hidden flex-1">
  <div class="w-full h-[200px] bg-primary-light overflow-hidden">
    <img src={photo} alt={name} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="flex flex-col gap-3 p-6">
    <h3 class="font-heading text-lg font-semibold text-text-primary">{name}</h3>
    <p class="font-body text-sm text-text-secondary">{credentials}</p>
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class:list={["font-body text-xs font-medium rounded-full px-2.5 py-1", tagColors[tag.color || "primary"]]}>
          {tag.label}
        </span>
      ))}
    </div>
  </div>
</div>
