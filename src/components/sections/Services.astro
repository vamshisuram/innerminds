---
import SectionHeader from "../SectionHeader.astro";
import CardService from "../CardService.astro";
---

<section id="services" class="w-full bg-bg-primary">
<div class="flex flex-col items-center gap-12 py-16 lg:py-24 px-6 md:px-12 lg:px-[120px] max-w-[1440px] mx-auto">
  <SectionHeader
    title="Our Services"
    subtitle="Five Pathways. One Responsibility-Based Framework."
  />
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
    <CardService
      icon="chat-circle"
      title="Corporate & Institutional Solutions"
      description="We embed Emotional Confidence and Behavioral Clarity into its foundations — culture, leadership, team effectiveness, and systems."
    />
    <CardService
      icon="brain"
      title="Individual Growth & Therapy"
      description="Structured work on responsibility, emotional regulation, and life transitions."
    />
    <CardService
      icon="scales"
      title="CTRT & Professional Development"
      description="Building behavioural capability in therapists, trainers, and faculty."
    />
    <CardService
      icon="heart"
      title="Returning Women to Work"
      description="We partner with returning women to work through structured programs that rebuild professional identity, emotional confidence, and workplace readiness."
    />
    <CardService
      icon="currency-circle-dollar"
      title="College campus to Corporate Corridors"
      description="Empowering Young Adults towards self-awareness and growth."
    />
  </div>
</div>
</section>
